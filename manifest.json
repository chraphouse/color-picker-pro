{
  "manifest_version": 3,
  "name": "Color Picker Pro",
  "version": "1.0.0",
  "description": "Pick any color from any webpage. Eyedropper tool, color history, and format converter (HEX, RGB, HSL).",

  "permissions": ["activeTab", "storage", "clipboardWrite"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+C" },
      "description": "Open color picker"
    }
  }
}
